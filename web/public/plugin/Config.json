{
    "name": "Stremio Addons",
    "description": "Your Stremio addons, unified into a single TMDB-powered library.",
    "author": "MTEIJ",
    "authorUrl": "https://github.com/mteij",
    "platformUrl": "https://greyjay-stremio.netlify.app",
    "repositoryUrl": "https://github.com/mteij/Grayjay-stremio-pluggin",
    "sourceUrl": "https://greyjay-stremio.netlify.app/plugin/Config.json",
    "scriptUrl": "https://greyjay-stremio.netlify.app/plugin/Script.js?v=1780828195",
    "version": 1780828195,
    "iconUrl": "https://greyjay-stremio.netlify.app/plugin/icon.png",
    "id": "e8e19e00-22c6-43b9-a411-cf0660601f01",
    "scriptSignature": "",
    "scriptPublicKey": "",
    "packages": [
        "Http",
        "Utilities",
        "DOMParser"
    ],
    "allowEval": false,
    "allowUrls": [
        "everywhere"
    ],
    "settings": [
        {
            "variable": "homeFeed",
            "name": "Home Screen Feed",
            "description": "Select what content to display on the Home screen.",
            "type": "options",
            "options": [
                "Trending (Default)",
                "Popular Movies",
                "Popular TV Shows",
                "Top Rated Movies",
                "Top Rated TV Shows",
                "Now Playing Movies"
            ],
            "default": "Trending (Default)"
        }
    ],
    "authentication": {
        "userAgent": "Mozilla/5.0 (Linux; Android 12) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.6099.230 Mobile Safari/537.36",
        "completionUrl": "https://greyjay-stremio.netlify.app/dashboard",
        "loginUrl": "https://greyjay-stremio.netlify.app/login",
        "cookiesToFind": [
            "grayjay-api-token"
        ]
    }
}